{
  "mcpServers": {
    "mcp10x": {
      "command": "/absolute/path/to/mcp10x/.venv/bin/python",
      "args": ["-m", "mcp10x", "--config", "/absolute/path/to/mcp10x/config.yaml"],
      "env": {
        "PYTHONPATH": "/absolute/path/to/mcp10x/src",
        "MCP10X_JIRA_PAT": "",
        "MCP10X_CONFLUENCE_PAT": "",
        "MCP10X_GITLAB_PAT": ""
      }
    }
  }
}
